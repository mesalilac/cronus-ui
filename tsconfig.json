{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "~/*": [
        "./src/*"
      ],
      "~/ui/*": [
        "./src/ui/*"
      ],
      "~/icons": [
        "./src/icons"
      ],
      "~/utils": [
        "./src/utils"
      ],
    },
    "types": [
      "node"
    ],
    "allowJs": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noUncheckedSideEffectImports": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true
  }
}