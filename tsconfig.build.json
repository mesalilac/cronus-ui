{
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "target": "esnext",
        "module": "esnext",
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "@/ui": [
                "./src/ui"
            ],
            "@/icons": [
                "./src/icons"
            ],
        }
    },
    "include": [
        "src"
    ]
}