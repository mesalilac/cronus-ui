    "devDependencies": {
        "@biomejs/biome": "^2.4.10",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^24.12.2",
        "@vitest/browser-playwright": "^4.1.2",
        "tailwindcss": "^4.2.2",
        "typescript": "~6.0.2",
        "vite": "^8.0.4",
        "vite-plugin-checker": "^0.12.0",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-solid": "^2.11.12",
        "rolldown-plugin-solid": "^0.2.1",
        "tsdown": "^0.21.7"
