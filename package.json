{
    "name": "cronus-ui",
    "private": true,
    "version": "0.2.1",
    "type": "module",
    "license": "MIT",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "solid": "./dist/index.jsx",
